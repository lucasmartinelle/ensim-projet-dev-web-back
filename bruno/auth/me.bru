meta {
  name: Me (profil courant)
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/auth/me
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

docs {
  ## Me

  Retourne le profil de l'utilisateur authentifié.

  Requiert un token JWT valide (utiliser **Login** d'abord).

  **Réponses :**
  - `200` : `{ user: { id, email, username, role } }`
  - `401` : token absent, invalide ou expiré
}
