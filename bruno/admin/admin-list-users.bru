meta {
  name: Admin - List Users
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/api/admin/users?page=1&limit=20
  body: none
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

tests {
  expect(res.getStatus()).to.equal(200);
  const body = res.getBody();
  expect(body).to.have.property('data').that.is.an('array');
  expect(body).to.have.property('total');
  expect(body).to.have.property('page', 1);
  expect(body).to.have.property('limit', 20);
}

docs {
  ## Admin — List Users

  Liste paginée des utilisateurs. Paramètres : `?page=&limit=&search=`.
  Requiert un token admin.

  **Réponse attendue :** `200` + `{ data, total, page, limit }`
}
