meta {
  name: Get Home Content (public)
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/home-content
  body: none
  auth: none
}

tests {
  expect(res.getStatus()).to.equal(200);
  const body = res.getBody();
  expect(body.content).to.be.an('array');
}

docs {
  ## Get Home Content (public)

  Retourne le contenu de la page d'accueil. Route publique (pas d'auth requise).

  **Réponse attendue :** `200` + `{ content: [...] }`
}
