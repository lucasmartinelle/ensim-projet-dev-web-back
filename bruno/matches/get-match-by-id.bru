meta {
  name: Get Match By ID
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/matches/{{matchId}}
  body: none
  auth: none
}

tests {
  expect(res.getStatus()).to.equal(200);
  const body = res.getBody();
  expect(body.match).to.have.property('id');
  expect(body.match).to.have.property('status');
}

docs {
  ## Get Match By ID

  Retourne le détail d'une partie. Route publique.
  Utilise `{{matchId}}` sauvegardé par Create Match.

  **Réponse attendue :** `200` + `{ match }`
}
