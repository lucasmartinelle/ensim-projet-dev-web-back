{
  "info": {
    "name": "GamePlatform API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection de test pour la plateforme de jeux en ligne.\n\n**Setup :**\n1. Importer l'environnement `GamePlatform — Local`\n2. Démarrer le serveur : `npm run dev`\n3. Lancer **Auth / Login** pour peupler automatiquement la variable `token`"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            },
            "description": "Vérifie que le serveur est opérationnel."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has status OK', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('OK');",
                  "  pm.expect(body.timestamp).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"player@example.com\",\n  \"username\": \"playerone\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Crée un nouveau compte utilisateur.\n\n**Validation :**\n- `email` : format email valide\n- `username` : 3-20 chars, alphanumérique + underscore\n- `password` : min 8 chars\n\n**Réponse attendue :** `201` + user sans passwordHash"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('User sans passwordHash', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.user).to.have.keys(['id','email','username','role','createdAt']);",
                  "  pm.expect(body.user).to.not.have.property('passwordHash');",
                  "  pm.expect(body.user.role).to.eql('PLAYER');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register — email dupliqué",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"player@example.com\",\n  \"username\": \"otherusername\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "**Réponse attendue :** erreur `Email already used`"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Erreur email dupliqué', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.eql('Email already used');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register — validation invalide",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"not-an-email\",\n  \"username\": \"ab\",\n  \"password\": \"short\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "**Réponse attendue :** erreur Zod (email invalide, username trop court, password trop court)"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"player@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Authentifie un utilisateur.\n\nLe token JWT est automatiquement sauvegardé dans la variable d'environnement `token`.\n\n**Réponse attendue :** `200` + `{ token, user }`"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token JWT présent', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.token).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.user).to.not.have.property('passwordHash');",
                  "  pm.environment.set('token', body.token);",
                  "  console.log('Token saved:', body.token.substring(0, 30) + '...');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login — mauvais mot de passe",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"player@example.com\",\n  \"password\": \"wrongpassword\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "**Réponse attendue :** erreur `Invalid credentials`"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Erreur credentials invalides', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message).to.eql('Invalid credentials');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Retourne le profil de l'utilisateur authentifié.\n\nNécessite un token valide — lancer **Login** d'abord.\n\n**Réponse attendue :** `200` + `{ user }`"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('User retourné', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.user).to.have.property('id');",
                  "  pm.expect(body.user).to.have.property('email');",
                  "  pm.expect(body.user).to.not.have.property('passwordHash');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Me — sans token",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "**Réponse attendue :** `401` `{ message: 'Unauthorized' }`"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Message Unauthorized', () => {",
                  "  pm.expect(pm.response.json().message).to.eql('Unauthorized');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Me — token invalide",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer invalidtoken" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "**Réponse attendue :** `401` `{ message: 'Unauthorized' }`"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
